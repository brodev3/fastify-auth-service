NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

POSTGRES_USER=fastify_auth
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_DB=fastify_auth

DATABASE_URL=postgresql://fastify_auth:replace-with-local-postgres-password@localhost:5432/fastify_auth?schema=public
REDIS_URL=redis://localhost:6379/0
TEST_DATABASE_URL=postgresql://fastify_auth:replace-with-local-postgres-password@localhost:5432/fastify_auth_test?schema=public
TEST_REDIS_URL=redis://localhost:6379/1

JWT_ACCESS_SECRET=replace-with-at-least-32-characters-for-access
JWT_REFRESH_SECRET=replace-with-a-different-32-character-refresh-secret
JWT_ISSUER=fastify-auth-service
JWT_ACCESS_AUDIENCE=fastify-auth-service:access
JWT_REFRESH_AUDIENCE=fastify-auth-service:refresh

CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
