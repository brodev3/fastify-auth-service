{
  "name": "fastify-auth-service",
  "version": "0.1.0",
  "private": true,
  "description": "Production-leaning REST authentication service built with Fastify.",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:validate": "prisma validate",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "npm@11.2.0",
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
